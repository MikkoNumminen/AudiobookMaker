#!/bin/bash
# Pre-commit hook: run tests before allowing commits.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

# Docs-only shortcut: if every staged change is a pure-asset or
# markdown-style file, skip the test suite entirely. Tests don't
# exercise docs, so running them costs ~12 s for no safety gain.
# Safety net: any non-doc file in the stage (even one) falls back to
# the full run.
#
# NOT in this list on purpose:
# - `.txt` (except LICENSE.txt, explicitly re-allowed): `requirements.txt`
#   is the only other tracked .txt and changes to it absolutely must run
#   tests — a silent dep bump that breaks runtime would otherwise land
#   without any signal.
# - `.yaml`: the `data/*.yaml` files drive the text normalizer (acronyms,
#   loanwords, governors) and tests explicitly exercise them, so a YAML
#   edit must run the suite.
DOC_PATTERN='\.(md|rst|gitattributes|gitignore|mp3|wav|ico|png|jpg)$|^(\.gitattributes|\.gitignore|TODO\.md|README\.md|BUILDING\.md|DEVELOPMENT\.md|CONVENTIONS\.md|LICENSE(\.txt)?)$'

staged=$(git diff --cached --name-only)
if [ -z "$staged" ]; then
    # Nothing staged (e.g. --amend with no changes). Fall through to
    # normal behaviour.
    non_doc=""
else
    # Files that aren't docs. If this is empty, we're docs-only.
    non_doc=$(echo "$staged" | grep -Ev "$DOC_PATTERN" || true)
fi

if [ -z "$non_doc" ] && [ -n "$staged" ]; then
    echo "Docs-only commit detected — skipping tests."
    echo "Staged: $staged"
    exit 0
fi

# Windows pytest-asyncio can occasionally hang inside ProactorEventLoop's
# internal socketpair() during test teardown. pytest-timeout catches it
# (pytest.ini sets timeout=60), but once in a while an otherwise-green
# run fails. Retry once before declaring the commit broken — real test
# failures are reproducible, flakes aren't.
#
# `-m "not slow"` honors the pytest.ini docstring: slow tests run a
# real engine end-to-end and are skipped by default in pre-commit.
# They still run in full CI / manual `pytest` invocations.
PYTEST_ARGS=(tests/ --ignore=tests/test_record_voice_sample.py -m "not slow" -x -q --tb=short)

run_tests() {
    py -3 -m pytest "${PYTEST_ARGS[@]}" 2>&1
}

echo "Running tests before commit..."
if run_tests; then
    echo "All tests passed."
    exit 0
fi

echo ""
echo "First test run failed — retrying once in case of a Windows asyncio flake..."
if run_tests; then
    echo "All tests passed on retry."
    exit 0
fi

echo ""
echo "Tests FAILED twice — commit blocked. Fix the failures and try again."
exit 1
