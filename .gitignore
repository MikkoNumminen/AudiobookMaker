.venv/
.venv-*/
# Also match the bare symlink form (no trailing slash) so local compatibility
# shims like `.venv-chatterbox -> .venv-qwen` stay out of git.
.venv-*
# Ignore the contents of .claude/ (settings, worktrees, caches) …
.claude/*
# … except for project-local Claude Code skills, which encode
# AudiobookMaker-specific workflow knowledge and must be shared across
# every session / worktree / contributor. `.claude/*` (not `.claude/`)
# is required so git will descend into the directory and see the
# re-included subpath.
!.claude/skills/
!.claude/skills/**
# Personal planning notes — kept locally, not part of the repo.
docs/plans/
__pycache__/
*.pyc
*.pyo
dist/
build/
# Ignore auto-generated specs but not our handcrafted ones
*.spec
!audiobookmaker.spec
!audiobookmaker_launcher.spec
*.egg-info/
.pytest_cache/
*.mp3
*.wav
!assets/voices/*.wav
!assets/voices/*.mp3
# Local model caches used by dev_qwen_tts.py and similar experiments
models/

# Windows / installer build artifacts
*.exe
installer/Output/
installer/*.iss.bak
installer/*.iss.swp
installer/Unicode/

# Code signing certificates — MUST NEVER be committed
*.pfx
*.p12

# Source PDFs / EPUBs — copyrighted material, must never be committed
*.pdf
*.epub

# Personal voice recordings used as Chatterbox --ref-audio clips.
# The user's own voice is personal data and must not be committed.
voice_samples/

# Voice-pack pipeline artefacts — KEEP LOCAL. These contain LoRA adapter
# weights trained on copyrighted source audio (audiobooks etc.). Sharing
# them would redistribute a voice clone of a third-party narrator, which
# is a legal/ethical minefield. Everything derived from a copyrighted
# source stays on the local disk.
voice_packs/
runs/
dataset_*/
analysis_*/
characters_*/
# Adapter / checkpoint weight files in any location.
*.safetensors
*.pt
*.ckpt
# Raw source audio beyond the generic *.wav/*.mp3 rules above.
*.m4b
*.ogg
*.mpeg
*.flac
# ECAPA / HuggingFace / torch hub download caches.
.cache/

# Visual Studio
.vs/
*.user
