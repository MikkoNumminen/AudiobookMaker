.venv/
.venv-*/
# Also match the bare symlink form (no trailing slash) so local compatibility
# shims like `.venv-chatterbox -> .venv-qwen` stay out of git.
.venv-*
# Ignore the contents of .claude/ (settings, worktrees, caches) …
.claude/*
# … except for project-local Claude Code skills, which encode
# AudiobookMaker-specific workflow knowledge and must be shared across
# every session / worktree / contributor. `.claude/*` (not `.claude/`)
# is required so git will descend into the directory and see the
# re-included subpath.
!.claude/skills/
!.claude/skills/**
# Kept local-only: copyright-scan uses concrete example strings
# (book titles / author names) as detection patterns that are
# forbidden in committed content. Skill stays functional locally.
.claude/skills/copyright-scan/
# Personal planning notes — kept locally, not part of the repo.
docs/plans/
# Local-only task list. Intentionally NOT tracked — keeps coordination
# notes (ownership tags, status markers) out of git history, where they
# have repeatedly leaked as AI-origin references in commit messages and
# diffs. Each machine keeps its own copy under the repo root.
TODO.md
__pycache__/
*.pyc
*.pyo
# Build / packaging output (PyInstaller, setuptools).
# dist/ is RESERVED for the PyInstaller build pipeline only — ffmpeg.exe
# build input lives at dist/ffmpeg/, frozen-exe output at dist/AudiobookMaker/,
# consumed by installer/setup.iss. Nothing runtime-generated goes here.
dist/
build/
# Runtime and dev-work output — audiobook MP3s, synthesis logs, diagnostic
# CSVs, stress-test outputs, scratch files from scripts. Anything the app
# or a dev script generates locally goes under out/.
out/
# Ignore auto-generated specs but not our handcrafted ones
*.spec
!audiobookmaker.spec
!audiobookmaker_launcher.spec
*.egg-info/
.pytest_cache/
*.mp3
*.wav
!assets/voices/*.wav
!assets/voices/*.mp3
# Local model caches used by dev_qwen_tts.py and similar experiments
models/

# Windows / installer build artifacts
*.exe
installer/Output/
installer/*.iss.bak
installer/*.iss.swp
installer/Unicode/

# Code signing certificates — MUST NEVER be committed
*.pfx
*.p12

# Local secrets and config. `.env` holds things like HF_TOKEN (for
# pyannote gating + large-model HF downloads). `.env.example` is tracked
# and lists the expected variables with empty placeholders.
.env
!.env.example

# Source PDFs / EPUBs — copyrighted material, must never be committed
*.pdf
*.epub

# Personal voice recordings used as Chatterbox --ref-audio clips.
# The user's own voice is personal data and must not be committed.
voice_samples/

# Local-only source material (third-party texts, audiobooks, test inputs).
# Put anything that shouldn't be pushed — copyrighted source files,
# per-user test fixtures, scratch data — under .local/.
.local/

# Voice-pack pipeline artefacts — KEEP LOCAL. These contain LoRA adapter
# weights trained on copyrighted source audio (audiobooks etc.). Sharing
# them would redistribute a voice clone of a third-party narrator, which
# is a legal/ethical minefield. Everything derived from a copyrighted
# source stays on the local disk.
voice_packs/
runs/
dataset_*/
analysis_*/
characters_*/
# Adapter / checkpoint weight files in any location.
*.safetensors
*.pt
*.ckpt
# Raw source audio beyond the generic *.wav/*.mp3 rules above.
*.m4b
*.ogg
*.mpeg
*.flac
# ECAPA / HuggingFace / torch hub download caches.
.cache/

# Visual Studio
.vs/
*.user
