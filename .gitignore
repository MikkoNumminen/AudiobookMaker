.venv/
.venv-*/
# Also match the bare symlink form (no trailing slash) so local compatibility
# shims like `.venv-chatterbox -> .venv-qwen` stay out of git.
.venv-*
.claude/
# Personal planning notes — kept locally, not part of the repo.
docs/plans/
__pycache__/
*.pyc
*.pyo
dist/
build/
# Ignore auto-generated specs but not our handcrafted ones
*.spec
!audiobookmaker.spec
!audiobookmaker_launcher.spec
*.egg-info/
.pytest_cache/
*.mp3
*.wav
!assets/voices/*.wav
!assets/voices/*.mp3
# Local model caches used by dev_qwen_tts.py and similar experiments
models/

# Windows / installer build artifacts
*.exe
installer/Output/
installer/*.iss.bak
installer/*.iss.swp
installer/Unicode/

# Code signing certificates — MUST NEVER be committed
*.pfx
*.p12

# Source PDFs — copyrighted material, must never be committed
*.pdf

# Personal voice recordings used as Chatterbox --ref-audio clips.
# The user's own voice is personal data and must not be committed.
voice_samples/

# Visual Studio
.vs/
*.user
